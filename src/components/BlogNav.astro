<script is:inline>
(function () {
  var toggle = document.getElementById("theme-toggle");
  if (!toggle) return;
  var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)");
  toggle.addEventListener("click", function () {
    var current = document.documentElement.getAttribute("data-theme") || "dark";
    var next = current === "dark" ? "light" : "dark";
    if (!prefersReduced.matches) document.documentElement.classList.add("theme-transition");
    document.documentElement.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
    toggle.setAttribute("aria-label", next === "dark" ? "Cambiar a modo claro" : "Cambiar a modo oscuro");
    var meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.content = next === "dark" ? "#0a0921" : "#f5f5f7";
    if (!prefersReduced.matches) {
      setTimeout(function () { document.documentElement.classList.remove("theme-transition"); }, 300);
    }
  });
})();
</script>
