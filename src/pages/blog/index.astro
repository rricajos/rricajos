---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogNav from '../../components/BlogNav.astro';
import BlogFooter from '../../components/BlogFooter.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Blog — RRicajos" description="Blog de RRicajos — desarrollo web, DevOps y diseño.">
  <BlogNav />
  <main class="container">
    <div class="page-header">
      <h1>Blog</h1>
      <p>Artículos sobre desarrollo web, DevOps y diseño.</p>
    </div>
    <div class="posts-grid">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </main>
  <BlogFooter />
</Base>

<style is:global>
  @import '../../styles/blog.css';
</style>
